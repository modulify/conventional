{
  "name": "@modulify/conventional-release",
  "type": "module",
  "version": "0.0.0",
  "license": "ISC",
  "homepage": "https://github.com/modulify/conventional/tree/main/packages/conventional-release#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./types": {
      "types": "./types/index.d.ts",
      "default": "./types/index.d.ts"
    },
    "./types/*": {
      "types": "./types/*.d.ts",
      "default": "./types/*.d.ts"
    }
  },
  "types": "dist/index.d.ts",
  "bin": "./bin/index.js",
  "peerDependencies": {
    "@types/node": ">=20",
    "@types/semver": "^7.7.1"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    },
    "@types/semver": {
      "optional": true
    }
  },
  "dependencies": {
    "@modulify/conventional-bump": "^0.0.0",
    "@modulify/conventional-changelog": "^0.0.0",
    "@modulify/git-toolkit": "^0.0.2",
    "@modulify/pkg": "^1.0.1",
    "chalk": "^5.6.2",
    "figures": "^6.1.0",
    "semver": "^7.7.3",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "@types/semver": "^7.7.1",
    "@types/yargs": "^17.0.35",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.16"
  },
  "author": {
    "name": "modulify",
    "email": "https://github.com/modulify"
  },
  "contributors": [
    {
      "name": "Zaitsev Kirill",
      "email": "zaytsev.cmath10@gmail.com"
    },
    {
      "name": "conventional-changelog team",
      "url": "https://github.com/conventional-changelog"
    }
  ],
  "keywords": [
    "conventional",
    "git",
    "release"
  ],
  "files": [
    "bin/*.cjs",
    "bin/*.js",
    "bin/*.mjs",
    "dist/*.cjs",
    "dist/*.mjs",
    "dist/*.d.ts",
    "types/*.d.ts",
    "LICENSE.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build-cli.mjs --prepare && vite build && node ./scripts/build-cli.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
