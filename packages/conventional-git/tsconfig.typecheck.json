{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "outDir": "../../artifacts/tsc/conventional-git",
    "tsBuildInfoFile": "../../artifacts/tsc/conventional-git.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"],
      "~tests/*": ["./tests/*"],
      "~types/*": ["./types/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.ts",
    "types/**/*.d.ts"
  ]
}
